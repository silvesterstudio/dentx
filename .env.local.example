# ── Copy this file to ".env.local" and fill in the real values. ──
# .env.local is git-ignored and stays on the server — these keys never reach the browser.

# Supabase (Project Settings → API)
#   SUPABASE_URL              = your Project URL, e.g. https://abcdxyz.supabase.co
#   SUPABASE_SERVICE_ROLE_KEY = the "service_role" secret key (NOT the anon key — keep it secret)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram booking notifications
#   TELEGRAM_BOT_TOKEN = token from @BotFather after /newbot
#   TELEGRAM_CHAT_ID   = your chat id (message the bot, then open
#                        https://api.telegram.org/bot<token>/getUpdates and read result[].message.chat.id;
#                        for a group, add the bot to it and use the negative group id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Admin panel password (you choose this — used to log in at /admin)
ADMIN_PASSWORD=
